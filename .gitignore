.venv/

# Local folders to ignore
plan/
temp/
ref/

# Benchmark outputs
benchmarks/data/
benchmarks/results/
benchmarks/results/tmp/
benchmarks/results/r_cache/

# Python bytecode and caches.
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Packaging and build outputs.
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Generated fixture logs remain local noise.
tests/fixtures/*.log

# Test, lint, and coverage artifacts.
.coverage
.coverage.*
.pytest_cache/
.ruff_cache/
.mypy_cache/
coverage.xml
htmlcov/

# Notebook and interactive session artifacts.
.ipynb_checkpoints/

# R session artifacts from fixture generation.
.Rhistory
.RData
.Ruserdata
renv/library/
renv/staging/
renv/sandbox/

# Editor and OS noise.
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
